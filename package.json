{
  "name": "spectra",
  "version": "0.1.0",
  "private": true,
  "description": "State-first testing framework for WebGL TV applications",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run --project example-tests",
    "test:watch": "vitest --project example-tests",
    "test:e2e": "playwright test",
    "test:e2e:auth": "npm run test:auth -w @spectra/example-tests",
    "build": "tsc -b packages/*/tsconfig.json",
    "typecheck": "tsc -b packages/*/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/browser": "^2.0.0",
    "playwright": "^1.44.0",
    "@playwright/test": "^1.44.0",
    "ws": "^8.17.0",
    "@types/ws": "^8.5.10",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "@types/pngjs": "^6.0.4",
    "tesseract.js": "^5.0.5"
  }
}
